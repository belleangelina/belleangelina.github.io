---
interface Props {
  title: string;
  url: string;
  summary?: string;
  date?: string;
  label?: string;
}

const { title, url, summary = '', date = '', label = '' } = Astro.props;
const meta = [label, date].filter(Boolean).join(' · ');
---

<article class="article-card">
  <a class="article-card-link" href={url}>
    {meta && <div class="meta article-card-meta">{meta}</div>}
    <h3>{title}</h3>
    {summary && <p>{summary}</p>}
    <span class="read-more">继续阅读</span>
  </a>
</article>
