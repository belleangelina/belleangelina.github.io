---
interface Props {
  title: string;
  url: string;
  date?: string;
  label?: string;
  cover?: string;
}

const { title, url, date = '', label = '', cover = '' } = Astro.props;
const meta = [label, date].filter(Boolean).join(' / ');
---

<article class="index-entry">
  <a class="index-entry-link" href={url}>
    <span class="index-entry-meta">{meta || 'Entry'}</span>
    <span class="index-entry-title">{title}</span>
    {cover && <img class="index-entry-image" src={cover} alt="" loading="lazy" />}
    <span class="index-entry-action">Read</span>
  </a>
</article>
