---
interface Props {
  title: string;
  url: string;
  date?: string;
  label?: string;
  cover?: string;
}

const { title, url, date = '', label = '', cover = '' } = Astro.props;
const meta = [label, date].filter(Boolean).join(' · ');
const stamp = label || 'Entry';
---

<article class="article-card">
  <a class="article-card-link" href={url}>
    <div class="article-cover" aria-hidden="true">
      {cover ? (
        <img class="article-cover-image" src={cover} alt="" loading="lazy" />
      ) : (
        <div class="article-cover-placeholder">
          <span></span>
        </div>
      )}
      <span class="article-cover-stamp">{stamp}</span>
    </div>
    <div class="article-card-body">
      {meta && <p class="article-card-meta">{meta}</p>}
      <h3>{title}</h3>
      <span class="article-card-cta">打开阅读</span>
    </div>
  </a>
</article>
