---
interface Props {
  title: string;
  url: string;
  date?: string;
  label?: string;
  cover?: string;
}

const { title, url, date = '', label = '', cover = '' } = Astro.props;
const meta = [label, date].filter(Boolean).join(' · ');
---

<article class="index-entry story-card">
  <a class="index-entry-link story-card-link" href={url}>
    <span class="story-card-art" aria-hidden="true">
      {cover ? <img class="index-entry-image story-card-image" src={cover} alt="" loading="lazy" /> : <span class="story-card-mark"></span>}
    </span>
    <span class="story-card-content">
      <span class="index-entry-meta story-card-meta">{meta || 'Entry'}</span>
      <span class="index-entry-title story-card-title">{title}</span>
    </span>
    <span class="index-entry-action story-card-action">Read</span>
  </a>
</article>
