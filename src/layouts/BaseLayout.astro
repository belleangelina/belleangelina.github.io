---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
}

const siteName = 'Belle Angelina';
const title = Astro.props.title ? `${Astro.props.title} · ${siteName}` : siteName;
const description = Astro.props.description ?? 'Belle Angelina 的小说、短篇和记录。';
const currentPath = Astro.url.pathname;

const navItems = [
    { href: '/', label: '首页' },
    { href: '/articles/', label: '文章' },
    { href: '/about/', label: '关于' }
];

function isActive(href: string) {
    if (href === '/') return currentPath === '/';
    return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#14112c" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <title>{title}</title>
        <link rel="alternate" type="application/rss+xml" title="Belle Angelina RSS" href="/rss.xml" />
        <script is:inline>
            (() => {
                const root = document.documentElement;

                try {
                    const stored = localStorage.getItem('belle-theme');
                    root.dataset.theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
                } catch (error) {
                    root.dataset.theme = 'dark';
                }
            })();
        </script>
    </head>
    <body>
        <div class="backdrop" aria-hidden="true"></div>
        <a class="skip-link" href="#content">跳到正文</a>

        <header class="nav" data-nav>
            <a class="nav__logo" href="/" aria-label="Belle Angelina 首页">
                <span class="nav__logo-mark" aria-hidden="true">◆</span>
                <span class="nav__logo-text">Belle</span>
            </a>

            <nav class="nav__menu" aria-label="主导航">
                {navItems.map((item) => (
                    <a class:list={{ active: isActive(item.href) }} href={item.href}>{item.label}</a>
                ))}
                <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换浅色主题">
                    <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
                        <circle cx="12" cy="12" r="3.5"></circle>
                        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
                    </svg>
                    <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20.2 15.3A8.5 8.5 0 0 1 8.7 3.8 8.5 8.5 0 1 0 20.2 15.3Z"></path>
                    </svg>
                </button>
            </nav>
        </header>

        <main id="content">
            <slot />
        </main>

        <footer class="footer">
            <div class="footer__inner">
                <p class="footer__quote">"写下那些值得被重新遇见的时刻。"</p>
                <p class="footer__meta">© <span data-current-year></span> Belle Angelina · Writings</p>
            </div>
        </footer>

        <script is:inline>
            (() => {
                const root = document.documentElement;
                const nav = document.querySelector('[data-nav]');
                const themeButton = document.querySelector('[data-theme-toggle]');
                const year = document.querySelector('[data-current-year]');

                function updateThemeLabel() {
                    if (!themeButton) return;

                    const isDark = root.dataset.theme === 'dark';
                    const label = isDark ? '切换浅色主题' : '切换暗色主题';
                    themeButton.setAttribute('aria-label', label);
                    themeButton.setAttribute('title', label);
                }

                themeButton?.addEventListener('click', () => {
                    const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
                    root.dataset.theme = nextTheme;

                    try {
                        localStorage.setItem('belle-theme', nextTheme);
                    } catch (error) {
                        // 浏览器禁止本地存储时，主题仍在当前页面生效。
                    }

                    updateThemeLabel();
                });

                function updateNav() {
                    nav?.classList.toggle('scrolled', window.scrollY > 30);
                }

                function runTypewriter() {
                    const target = document.querySelector('[data-typewriter]');
                    if (!target) return;

                    const lines = [
                        '把长篇、短篇和记录安静收好。',
                        '不追求喧闹，只留下真正想写的东西。',
                        '适合慢慢打开，也适合继续读下去。'
                    ];
                    let lineIndex = 0;
                    let charIndex = 0;
                    let deleting = false;

                    const tick = () => {
                        const current = lines[lineIndex];
                        target.textContent = current.slice(0, charIndex);

                        if (!deleting && charIndex < current.length) {
                            charIndex += 1;
                        } else if (!deleting) {
                            deleting = true;
                            window.setTimeout(tick, 1800);
                            return;
                        } else if (charIndex > 0) {
                            charIndex -= 1;
                        } else {
                            deleting = false;
                            lineIndex = (lineIndex + 1) % lines.length;
                        }

                        window.setTimeout(tick, deleting ? 34 : 72);
                    };

                    tick();
                }

                function observeReveal() {
                    const items = document.querySelectorAll('.reveal, [data-reveal]');

                    if (!('IntersectionObserver' in window)) {
                        items.forEach((item) => item.classList.add('in', 'is-visible'));
                        return;
                    }

                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add('in', 'is-visible');
                                observer.unobserve(entry.target);
                            }
                        });
                    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

                    items.forEach((item) => observer.observe(item));
                }

                window.addEventListener('scroll', updateNav, { passive: true });
                updateNav();
                updateThemeLabel();
                runTypewriter();
                observeReveal();

                if (year) {
                    year.textContent = String(new Date().getFullYear());
                }
            })();
        </script>
    </body>
</html>
