---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    image?: string;
    contentType?: 'website' | 'article';
    publishedTime?: string;
    readingEntry?: {
        title: string;
        url: string;
    };
}

const siteName = '天然未来派的摸鱼小屋';
const title = Astro.props.title ? `${Astro.props.title} · ${siteName}` : siteName;
const description = Astro.props.description ?? `${siteName}：长篇、短篇和笔记。`;
const readingEntry = Astro.props.readingEntry;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site ?? Astro.url.origin).toString();
const socialImage = Astro.props.image ? new URL(Astro.props.image, Astro.site ?? Astro.url.origin).toString() : null;
const contentType = Astro.props.contentType ?? 'website';
const publishedTime = Astro.props.publishedTime;

const navItems = [
    { href: '/', label: '首页' },
    { href: '/articles/', label: '文章' },
    { href: '/about/', label: '关于' }
];

function isActive(href: string) {
    if (href === '/') return currentPath === '/';
    return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#f8f5ff" data-theme-color />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={contentType} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:locale" content="zh_CN" />
        {socialImage && <meta property="og:image" content={socialImage} />}
        {contentType === 'article' && publishedTime && <meta property="article:published_time" content={`${publishedTime}T00:00:00Z`} />}
        <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {socialImage && <meta name="twitter:image" content={socialImage} />}
        <title>{title}</title>
        <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href="/rss.xml" />
        <script is:inline>
            (() => {
                const root = document.documentElement;
                const themeColor = document.querySelector('[data-theme-color]');
                root.classList.add('js');

                try {
                    const stored = localStorage.getItem('belle-theme-v2');
                    root.dataset.theme = stored === 'light' || stored === 'dark' ? stored : 'light';
                } catch (error) {
                    root.dataset.theme = 'light';
                }

                themeColor?.setAttribute('content', root.dataset.theme === 'dark' ? '#070316' : '#f8f5ff');
            })();
        </script>
    </head>
    <body>
        <div class="aurora" aria-hidden="true"></div>
        <div class="backdrop" aria-hidden="true"></div>
        <a class="skip-link" href="#content">跳到正文</a>

        <header class="nav" data-nav>
            <a class="nav__logo" href="/" aria-label={`${siteName} 首页`}>
                <span class="nav__logo-mark" aria-hidden="true">◆</span>
                <span class="nav__logo-text">{siteName}</span>
            </a>

            <nav class="nav__menu" aria-label="主导航">
                {navItems.map((item) => (
                    <a class:list={{ active: isActive(item.href) }} href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
                ))}
                <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换浅色主题">
                    <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
                        <circle cx="12" cy="12" r="3.5"></circle>
                        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
                    </svg>
                    <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20.2 15.3A8.5 8.5 0 0 1 8.7 3.8 8.5 8.5 0 1 0 20.2 15.3Z"></path>
                    </svg>
                </button>
            </nav>
        </header>

        <main id="content">
            <slot />
        </main>

        <footer class="footer">
            <div class="footer__inner">
                <p class="footer__meta">© <span data-current-year></span> {siteName} · Writings</p>
            </div>
        </footer>

        {readingEntry && (
            <script is:inline define:vars={{ readingEntry }}>
                (() => {
                    const storageKey = 'belle-last-reading-v1';
                    const shouldRestore = new URLSearchParams(window.location.search).get('continue') === '1';

                    function getMaxScroll() {
                        return Math.max(document.documentElement.scrollHeight - window.innerHeight, 0);
                    }

                    function saveReading() {
                        const maxScroll = getMaxScroll();
                        const scrollY = Math.min(Math.max(Math.round(window.scrollY), 0), maxScroll);
                        const progress = maxScroll > 0 ? scrollY / maxScroll : 0;

                        try {
                            localStorage.setItem(storageKey, JSON.stringify({
                                title: readingEntry.title,
                                url: readingEntry.url,
                                scrollY,
                                progress,
                                savedAt: new Date().toISOString()
                            }));
                        } catch (error) {
                            // 浏览器禁止本地存储时，不记录继续阅读位置。
                        }
                    }

                    function restoreReading() {
                        if (!shouldRestore) return;

                        try {
                            const stored = JSON.parse(localStorage.getItem(storageKey) || 'null');
                            if (!stored || stored.url !== readingEntry.url || typeof stored.scrollY !== 'number') return;

                            const targetY = Math.min(Math.max(stored.scrollY, 0), getMaxScroll());
                            window.scrollTo(0, targetY);
                            window.history.replaceState(null, '', `${window.location.pathname}${window.location.hash}`);
                        } catch (error) {
                            // 本地阅读记录不可用时，从正文顶部开始阅读。
                        }
                    }

                    let saveTimer = 0;

                    function queueSaveReading() {
                        if (saveTimer) return;

                        saveTimer = window.setTimeout(() => {
                            saveTimer = 0;
                            saveReading();
                        }, 300);
                    }

                    function flushReading() {
                        window.clearTimeout(saveTimer);
                        saveTimer = 0;
                        saveReading();
                    }

                    window.addEventListener('scroll', queueSaveReading, { passive: true });
                    window.addEventListener('pagehide', flushReading);
                    document.addEventListener('visibilitychange', () => {
                        if (document.visibilityState === 'hidden') flushReading();
                    });

                    if (shouldRestore) {
                        window.requestAnimationFrame(restoreReading);
                        window.addEventListener('load', () => {
                            restoreReading();
                            window.requestAnimationFrame(saveReading);
                        }, { once: true });
                    } else {
                        window.requestAnimationFrame(saveReading);
                    }
                })();
            </script>
        )}

        <script is:inline>
            (() => {
                const root = document.documentElement;
                const nav = document.querySelector('[data-nav]');
                const themeButton = document.querySelector('[data-theme-toggle]');
                const themeColor = document.querySelector('[data-theme-color]');
                const year = document.querySelector('[data-current-year]');
                let themeSwitchTimer = 0;
                let navUpdateQueued = false;

                function updateThemeLabel() {
                    if (!themeButton) return;

                    const isDark = root.dataset.theme === 'dark';
                    const label = isDark ? '切换浅色主题' : '切换暗色主题';
                    themeButton.setAttribute('aria-label', label);
                    themeButton.setAttribute('title', label);
                    themeColor?.setAttribute('content', isDark ? '#070316' : '#f8f5ff');
                }

                themeButton?.addEventListener('click', () => {
                    const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
                    root.classList.add('theme-switching');
                    window.clearTimeout(themeSwitchTimer);
                    themeSwitchTimer = window.setTimeout(() => {
                        root.classList.remove('theme-switching');
                    }, 520);

                    root.dataset.theme = nextTheme;

                    try {
                        localStorage.setItem('belle-theme-v2', nextTheme);
                    } catch (error) {
                        // 浏览器禁止本地存储时，主题仍在当前页面生效。
                    }

                    updateThemeLabel();
                });

                function updateNav() {
                    if (!nav) return;

                    const progress = Math.min(Math.max(window.scrollY / 120, 0), 1);
                    nav.style.setProperty('--nav-light-alpha', (progress * 0.46).toFixed(3));
                    nav.style.setProperty('--nav-dark-alpha', (progress * 0.12).toFixed(3));
                    nav.style.setProperty('--nav-light-blur', `${(progress * 22).toFixed(2)}px`);
                    nav.style.setProperty('--nav-dark-blur', `${(progress * 14).toFixed(2)}px`);
                    nav.style.setProperty('--nav-overlay-opacity', progress.toFixed(3));
                    nav.classList.toggle('scrolled', progress > 0.01);
                }

                function runTypewriter() {
                    const target = document.querySelector('[data-typewriter]');
                    if (!target) return;

                    const lines = [
                        '一个写代码的人，顺便记点东西。',
                        '写代码，也写小说，偶尔记点别的。'
                    ];

                    target.textContent = lines[0];
                    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

                    let lineIndex = 0;
                    let charIndex = 0;
                    let deleting = false;

                    const tick = () => {
                        const current = lines[lineIndex];
                        target.textContent = current.slice(0, charIndex);

                        if (!deleting && charIndex < current.length) {
                            charIndex += 1;
                        } else if (!deleting) {
                            deleting = true;
                            window.setTimeout(tick, 1800);
                            return;
                        } else if (charIndex > 0) {
                            charIndex -= 1;
                        } else {
                            deleting = false;
                            lineIndex = (lineIndex + 1) % lines.length;
                        }

                        window.setTimeout(tick, deleting ? 34 : 72);
                    };

                    tick();
                }

                function queueNavUpdate() {
                    if (navUpdateQueued) return;

                    navUpdateQueued = true;
                    window.requestAnimationFrame(() => {
                        navUpdateQueued = false;
                        updateNav();
                    });
                }

                function observeReveal() {
                    const groups = document.querySelectorAll('[data-reveal-group]');
                    const items = document.querySelectorAll('.reveal:not([data-reveal-child]), [data-reveal]:not([data-reveal-child])');

                    function revealItem(item) {
                        item.classList.add('in', 'is-visible');
                    }

                    function revealGroup(group) {
                        const children = group.querySelectorAll('.reveal, [data-reveal]');
                        children.forEach(revealItem);
                    }

                    if (!('IntersectionObserver' in window)) {
                        items.forEach(revealItem);
                        groups.forEach(revealGroup);
                        return;
                    }

                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                if (entry.target.hasAttribute('data-reveal-group')) {
                                    revealGroup(entry.target);
                                } else {
                                    revealItem(entry.target);
                                }

                                observer.unobserve(entry.target);
                            }
                        });
                    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

                    items.forEach((item) => observer.observe(item));
                    groups.forEach((group) => observer.observe(group));
                }

                window.addEventListener('scroll', queueNavUpdate, { passive: true });
                updateNav();
                updateThemeLabel();
                root.classList.add('theme-ready');
                runTypewriter();
                observeReveal();

                if (year) {
                    year.textContent = String(new Date().getFullYear());
                }
            })();
        </script>
    </body>
</html>
