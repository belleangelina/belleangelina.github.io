---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getRecentArticles, getPublishedNovels, getPublishedShorts, getPublishedNotes } from '../lib/content';

const [recent, novels, shorts, notes] = await Promise.all([
  getRecentArticles(3),
  getPublishedNovels(),
  getPublishedShorts(),
  getPublishedNotes()
]);

const total = novels.length + shorts.length + notes.length;
---

<BaseLayout title="首页" description="Belle Angelina 的文章、小说和记录。">
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-copy">
      <p class="overline">Belle Angelina · Moonlit Pages</p>
      <h1 id="home-title">月雾里的一间文字小屋</h1>
      <p class="home-lede">小说、短篇、记录都安静放在这里。色彩收轻，装饰留白，只让入口清楚、文字舒服、气质像一封慢慢展开的信。</p>
      <div class="hero-actions">
        <a class="button" href="/articles/">进入目录</a>
        <a class="button-secondary" href="/articles/novels/">阅读长篇</a>
      </div>
    </div>

    <aside class="moon-scene" aria-label="站点概览">
      <div class="moon-card" aria-hidden="true">
        <span class="moon-orb"></span>
        <span class="paper-line paper-line-one"></span>
        <span class="paper-line paper-line-two"></span>
        <span class="paper-line paper-line-three"></span>
      </div>
      <div class="home-marquee">
        <span class="marquee-label">Collected</span>
        <strong>{total}</strong>
        <span>published pieces</span>
      </div>
    </aside>
  </section>

  <section class="collection-board" aria-label="主要入口">
    <a class="collection-tile collection-tile-featured" href="/articles/novels/">
      <span class="tile-index">01</span>
      <span class="tile-label">Novel</span>
      <strong>长篇</strong>
      <em>{novels.length} 部连续故事</em>
    </a>
    <a class="collection-tile" href="/articles/shorts/">
      <span class="tile-index">02</span>
      <span class="tile-label">Shorts</span>
      <strong>短篇</strong>
      <em>{shorts.length} 篇独立片段</em>
    </a>
    <a class="collection-tile" href="/articles/notes/">
      <span class="tile-index">03</span>
      <span class="tile-label">Notes</span>
      <strong>记录</strong>
      <em>{notes.length} 篇日常整理</em>
    </a>
  </section>

  <section class="section recent-salon" aria-labelledby="recent-title">
    <div class="section-head section-head-large">
      <div>
        <p class="overline">Recently Updated</p>
        <h2 id="recent-title">最近更新</h2>
      </div>
      <a href="/articles/">全部文章</a>
    </div>
    {recent.length > 0 ? (
      <div class="article-list article-list-featured">
        {recent.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} cover={article.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布内容。</p>
    )}
  </section>
</BaseLayout>
