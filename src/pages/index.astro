---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getRecentArticles } from '../lib/content';

const recent = await getRecentArticles(2);

const categoryPanels = [
    {
        id: 'category-novels',
        href: '/articles/novels/',
        title: '长篇',
        summary: '连续故事与章节被整理成册，适合按卷慢慢读。'
    },
    {
        id: 'category-shorts',
        href: '/articles/shorts/',
        title: '短篇',
        summary: '独立片段和短故事，保留一些单独发光的时刻。'
    },
    {
        id: 'category-notes',
        href: '/articles/notes/',
        title: '记录',
        summary: '日常整理、临时想法和生活旁注，被收进更轻的一格。'
    }
];
---

<BaseLayout title="首页" description="Belle Angelina 的小说、短篇和记录。">
    <div class="page">
        <section class="hero">
            <h1 class="hero__title">Belle Angelina</h1>
            <p class="hero__subtitle">
                <span data-typewriter></span><span class="typed-cursor"></span>
            </p>
            <div class="hero__actions">
                <a class="btn btn--primary" href="/articles/"><span>进入目录</span></a>
                <a class="btn btn--ghost" href="/articles/shorts/">读短篇</a>
            </div>
        </section>

        <div class="category-panels" aria-label="内容分类">
            {categoryPanels.map((panel) => (
                <section class="category-panel reveal" id={panel.id}>
                    <h2>{panel.title}</h2>
                    <p>{panel.summary}</p>
                    <a class="btn btn--ghost" href={panel.href}>进入{panel.title}</a>
                </section>
            ))}
        </div>

        <section class="section" id="recent">
            <div class="section__head reveal">
                <h2 class="section__title">最近记录</h2>
                <p class="section__desc">只留两个最近入口，其他内容都放回各自目录。</p>
            </div>

            {recent.length > 0 ? (
                <div class="articles-grid">
                    {recent.map((article) => (
                        <ArticleCard
                            title={article.title}
                            url={article.url}
                            date={article.date}
                            label={article.kind === 'note' ? '记录' : article.kind === 'short' ? '短篇' : '章节'}
                        />
                    ))}
                </div>
            ) : (
                <p class="empty">暂时还没有已发布内容。</p>
            )}
        </section>
    </div>
</BaseLayout>
