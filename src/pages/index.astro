---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedNotes, getPublishedNovels, getPublishedShorts } from '../lib/content';

type HomeEntry = {
    title: string;
    url: string;
    date: string;
};

const [novels, shorts, notes] = await Promise.all([
    getPublishedNovels(),
    getPublishedShorts(),
    getPublishedNotes()
]);

function latestByDate<T extends HomeEntry>(items: T[]): T | null {
    return [...items].sort((a, b) => {
        const dateCompare = b.date.localeCompare(a.date);
        if (dateCompare !== 0) return dateCompare;
        return a.title.localeCompare(b.title);
    })[0] ?? null;
}

const latestChapters = novels.flatMap((novel) => novel.volumes.flatMap((volume) => volume.chapters));
const latestNovel = latestByDate(latestChapters.length > 0 ? latestChapters : novels);

const categoryPanels = [
    {
        id: 'category-novels',
        href: '/articles/novels/',
        title: '长篇',
        latestLabel: '最新长篇',
        latest: latestNovel,
        emptyTitle: '长篇整理中',
        emptyMeta: '新的章节会放在这里'
    },
    {
        id: 'category-shorts',
        href: '/articles/shorts/',
        title: '短篇',
        latestLabel: '最新短篇',
        latest: latestByDate(shorts),
        emptyTitle: '短篇整理中',
        emptyMeta: '新的短篇会放在这里'
    },
    {
        id: 'category-notes',
        href: '/articles/notes/',
        title: '记录',
        latestLabel: '最新记录',
        latest: latestByDate(notes),
        emptyTitle: '记录整理中',
        emptyMeta: '新的记录会放在这里'
    }
];
---

<BaseLayout title="首页" description="天然未来派的摸鱼小屋的小说、短篇和记录。">
    <div class="page">
        <section class="hero">
            <h1 class="hero__title">天然未来派的摸鱼小屋</h1>
            <p class="hero__subtitle">
                <span data-typewriter></span><span class="typed-cursor"></span>
            </p>
            <div class="hero__actions">
                <a class="btn btn--primary" href="/articles/"><span>进入目录</span></a>
                <a class="btn btn--ghost" href="/articles/">随便看看</a>
            </div>
        </section>

        <div class="category-panels" aria-label="内容分类">
            {categoryPanels.map((panel) => {
                const latest = panel.latest;
                const cardMeta = latest ? [latest.date, panel.latestLabel].filter(Boolean).join(' · ') : panel.emptyMeta;

                return (
                    <section class="category-panel reveal" id={panel.id}>
                        <div class="category-panel__inner">
                            <div class="category-panel__copy">
                                <h2>{panel.title}</h2>
                                <a class="btn btn--primary" href={panel.href}><span>目录</span></a>
                            </div>

                            <a class:list={['category-feature', { 'is-empty': !latest }]} href={latest?.url ?? panel.href}>
                                <span class="category-feature__label">{latest ? panel.latestLabel : '暂未发布'}</span>
                                <strong>{latest?.title ?? panel.emptyTitle}</strong>
                                <span class="category-feature__meta">{cardMeta}</span>
                                <span class="category-feature__read">{latest ? '阅读 →' : '去目录 →'}</span>
                            </a>
                        </div>
                    </section>
                );
            })}
        </div>
    </div>
</BaseLayout>
