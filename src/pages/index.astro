---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedNotes, getPublishedNovels, getPublishedShorts } from '../lib/content';

type HomeEntry = {
    title: string;
    url: string;
    date: string;
};

const [novels, shorts, notes] = await Promise.all([
    getPublishedNovels(),
    getPublishedShorts(),
    getPublishedNotes()
]);

function latestByDate<T extends HomeEntry>(items: T[]): T | null {
    return [...items].sort((a, b) => {
        const dateCompare = b.date.localeCompare(a.date);
        if (dateCompare !== 0) return dateCompare;
        return a.title.localeCompare(b.title);
    })[0] ?? null;
}

const latestChapters = novels.flatMap((novel) => novel.volumes.flatMap((volume) => volume.chapters));
const novelCandidates: HomeEntry[] = latestChapters.length > 0 ? latestChapters : novels;
const latestNovel = latestByDate(novelCandidates);
const firstNovelChapters: HomeEntry[] = [];

novels.forEach((novel) => {
    const firstChapter = novel.volumes.flatMap((volume) => volume.chapters)[0];
    if (firstChapter) firstNovelChapters.push(firstChapter);
});

const randomReadingTargets = [...firstNovelChapters, ...shorts, ...notes].map((item) => item.url);
const knownReadingTargets = [...latestChapters, ...shorts, ...notes].map((item) => item.url);
const randomReadingFallback = randomReadingTargets[0] ?? '/articles/';

const categoryPanels = [
    {
        id: 'category-novels',
        href: '/articles/novels/',
        title: '长篇',
        latestLabel: '最新长篇',
        latest: latestNovel,
        emptyTitle: '长篇整理中',
        emptyMeta: '新的章节会放在这里'
    },
    {
        id: 'category-shorts',
        href: '/articles/shorts/',
        title: '短篇',
        latestLabel: '最新短篇',
        latest: latestByDate(shorts),
        emptyTitle: '短篇整理中',
        emptyMeta: '新的短篇会放在这里'
    },
    {
        id: 'category-notes',
        href: '/articles/notes/',
        title: '记录',
        latestLabel: '最新记录',
        latest: latestByDate(notes),
        emptyTitle: '记录整理中',
        emptyMeta: '新的记录会放在这里'
    }
];
---

<BaseLayout title="首页" description="天然未来派的摸鱼小屋的小说、短篇和记录。">
    <div class="page">
        <section class="hero">
            <h1 class="hero__title">天然未来派的摸鱼小屋</h1>
            <p class="hero__subtitle">
                <span class="visually-hidden">一个写代码的人，顺便记点东西。</span>
                <span data-typewriter aria-hidden="true">一个写代码的人,顺便记点东西。</span><span class="typed-cursor" aria-hidden="true"></span>
            </p>
            <div class="hero__actions">
                <a class="btn btn--primary" href="/articles/"><span>进入目录</span></a>
                <a
                    class="btn btn--ghost"
                    href={randomReadingFallback}
                    data-random-reading
                    data-random-reading-targets={JSON.stringify(randomReadingTargets)}
                    data-known-reading-targets={JSON.stringify(knownReadingTargets)}
                >随便看看</a>
            </div>
        </section>

        <div class="category-panels" aria-label="内容分类">
            {categoryPanels.map((panel) => {
                const latest = panel.latest;
                const cardMeta = latest ? [latest.date, panel.latestLabel].filter(Boolean).join(' · ') : panel.emptyMeta;

                return (
                    <section class="category-panel" id={panel.id} data-reveal-group>
                        <div class="category-panel__inner">
                            <div class="category-panel__copy">
                                <h2 class="reveal reveal--delay-1" data-reveal-child>
                                    <a href={panel.href}>{panel.title}</a>
                                </h2>
                                <a class="btn btn--primary reveal reveal--delay-2" href={panel.href} data-reveal-child><span>目录</span></a>
                            </div>

                            <a class:list={['category-feature', 'reveal', 'reveal--delay-3', { 'is-empty': !latest }]} href={latest?.url ?? panel.href} data-reveal-child>
                                <span class="category-feature__label">{latest ? panel.latestLabel : '暂未发布'}</span>
                                <strong>{latest?.title ?? panel.emptyTitle}</strong>
                                <span class="category-feature__meta">{cardMeta}</span>
                                <span class="category-feature__read">{latest ? '阅读 →' : '去目录 →'}</span>
                            </a>
                        </div>
                    </section>
                );
            })}
        </div>
    </div>

    <script is:inline>
        (() => {
            const button = document.querySelector('[data-random-reading]');
            if (!button) return;

            const lastReadingKey = 'belle-last-reading-v1';
            const randomTargets = JSON.parse(button.dataset.randomReadingTargets || '[]');
            const knownTargets = new Set(JSON.parse(button.dataset.knownReadingTargets || '[]'));

            function withContinueParam(url) {
                return `${url}${url.includes('?') ? '&' : '?'}continue=1`;
            }

            try {
                const stored = JSON.parse(localStorage.getItem(lastReadingKey) || 'null');

                if (stored && typeof stored.url === 'string' && knownTargets.has(stored.url)) {
                    button.textContent = '继续阅读';
                    button.href = withContinueParam(stored.url);
                    button.dataset.continueReading = 'true';

                    if (typeof stored.title === 'string' && stored.title) {
                        button.setAttribute('aria-label', `继续阅读：${stored.title}`);
                    }
                }
            } catch (error) {
                // 本地阅读记录不可用时保持随机阅读入口。
            }

            button.addEventListener('click', (event) => {
                if (button.dataset.continueReading === 'true' || randomTargets.length === 0) return;

                event.preventDefault();
                const index = Math.floor(Math.random() * randomTargets.length);
                window.location.assign(randomTargets[index]);
            });
        })();
    </script>
</BaseLayout>
