---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getRecentArticles } from '../lib/content';

const recent = await getRecentArticles(2);
---

<BaseLayout title="首页" description="Belle Angelina 的文章、小说和记录。">
  <section class="home-hero" aria-labelledby="home-title">
    <h1 id="home-title">一些记录</h1>
    <div class="hero-actions">
      <a class="button" href="/articles/">进入目录</a>
      <a class="button-secondary" href="/articles/shorts/">读短篇</a>
    </div>
  </section>

  <section class="entry-sections" aria-label="主要入口">
    <a class="entry-section" href="/articles/novels/">
      <span>长篇</span>
      <strong>连续故事</strong>
    </a>
    <a class="entry-section" href="/articles/shorts/">
      <span>短篇</span>
      <strong>独立片段</strong>
    </a>
    <a class="entry-section" href="/articles/notes/">
      <span>记录</span>
      <strong>日常整理</strong>
    </a>
  </section>

  <section class="section" aria-labelledby="recent-title">
    <div class="section-head">
      <h2 id="recent-title">最近更新</h2>
      <a href="/articles/">全部文章</a>
    </div>
    {recent.length > 0 ? (
      <div class="article-list article-list-featured">
        {recent.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} cover={article.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布内容。</p>
    )}
  </section>
</BaseLayout>
