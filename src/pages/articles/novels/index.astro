---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedNovels } from '../../../lib/content';

const novels = await getPublishedNovels();
---

<BaseLayout title="长篇" description="长篇作品列表。">
  <section class="archive-hero category-hero" aria-labelledby="novels-title">
    <div>
      <p class="overline">Long Form</p>
      <h1 id="novels-title">长篇</h1>
      <p class="archive-lede">连续故事与章节被整理成册，像展厅里较长的一面墙。</p>
    </div>
    <div class="archive-counter" aria-label="长篇数量">
      <strong>{novels.length}</strong>
      <span>collections</span>
    </div>
  </section>

  <section class="section archive-listing" aria-labelledby="novels-list-title">
    <div class="section-head section-head-large">
      <div>
        <p class="overline">Shelf</p>
        <h2 id="novels-list-title">长篇作品</h2>
      </div>
      <span class="meta">{novels.length} 部</span>
    </div>
    {novels.length > 0 ? (
      <div class="article-list">
        {novels.map((novel) => (
          <ArticleCard title={novel.title} url={novel.url} date={novel.date} label={`${novel.volumes.length} 卷`} cover={novel.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布长篇作品。</p>
    )}
  </section>
</BaseLayout>
