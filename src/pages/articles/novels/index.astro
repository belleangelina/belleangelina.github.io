---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedNovels } from '../../../lib/content';

const novels = await getPublishedNovels();
---

<BaseLayout title="长篇" description="长篇作品列表。">
  <section class="hero">
    <h1>长篇</h1>
  </section>

  <section class="section article-list-section" aria-labelledby="novels-title">
    <div class="section-head">
      <h2 id="novels-title">长篇作品</h2>
      <span class="meta">{novels.length} 部</span>
    </div>
    {novels.length > 0 ? (
      <div class="article-list">
        {novels.map((novel) => (
          <ArticleCard title={novel.title} url={novel.url} date={novel.date} label={`${novel.volumes.length} 卷`} cover={novel.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布长篇作品。</p>
    )}
  </section>
</BaseLayout>
