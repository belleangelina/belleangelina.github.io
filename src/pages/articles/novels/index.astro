---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedNovels } from '../../../lib/content';

const novels = await getPublishedNovels();
---

<BaseLayout title="长篇" description="长篇作品列表。">
  <section class="archive-hero category-hero" aria-labelledby="novels-title">
    <div>
      <h1 id="novels-title" class="reveal reveal--delay-1">长篇</h1>
      <p class="archive-lede reveal reveal--delay-2">按作品、卷和章节整理。</p>
    </div>
  </section>

  <section class="section archive-listing" aria-labelledby="novels-list-title">
    <h2 id="novels-list-title" class="visually-hidden">长篇列表</h2>
    {novels.length > 0 ? (
      <div class="article-list reveal reveal--delay-3">
        {novels.map((novel) => (
          <ArticleCard title={novel.title} url={novel.url} date={novel.date} label="长篇" />
        ))}
      </div>
    ) : (
      <p class="empty reveal reveal--delay-3">暂无长篇。</p>
    )}
  </section>
</BaseLayout>
