---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { getPublishedNovels } from '../../../../../lib/content';

export async function getStaticPaths() {
  const novels = await getPublishedNovels();
  const paths = [];

  for (const novel of novels) {
    const allChapters = novel.volumes.flatMap((volume) => volume.chapters.map((chapter) => ({ volume, chapter })));

    for (let index = 0; index < allChapters.length; index += 1) {
      const current = allChapters[index];
      paths.push({
        params: {
          novel: novel.slug,
          volume: current.volume.slug,
          chapter: current.chapter.slug
        },
        props: {
          novel,
          volume: current.volume,
          chapter: current.chapter,
          previous: allChapters[index - 1]?.chapter ?? null,
          next: allChapters[index + 1]?.chapter ?? null
        }
      });
    }
  }

  return paths;
}

const { novel, volume, chapter, previous, next } = Astro.props;
---

<BaseLayout
  title={chapter.title}
  description={chapter.summary || chapter.title}
  image={chapter.cover || novel.cover}
  contentType="article"
  publishedTime={chapter.date}
  readingEntry={{ title: chapter.title, url: chapter.url }}
>
  <article class="reading">
    <header class="reading-header">
      <div class="eyebrow"><a href={novel.url}>{novel.title}</a> / <a href={volume.url}>{volume.title}</a></div>
      <h1>{chapter.title}</h1>
    </header>

    <div class="prose" set:html={chapter.html} />

    <nav class="chapter-nav" aria-label="章节导航">
      {previous ? (
        <a class="chapter-nav__item chapter-nav__item--previous" href={previous.url}>
          <span>← 上一章</span>
          <strong>{previous.title}</strong>
        </a>
      ) : (
        <span class="chapter-nav__item chapter-nav__item--previous chapter-nav__item--disabled">
          <span>上一章</span>
          <strong>已经是第一章</strong>
        </span>
      )}
      <a class="chapter-nav__item chapter-nav__item--toc" href={novel.url}>
        <span>目录</span>
        <strong>返回目录</strong>
      </a>
      {next ? (
        <a class="chapter-nav__item chapter-nav__item--next" href={next.url}>
          <span>下一章 →</span>
          <strong>{next.title}</strong>
        </a>
      ) : (
        <span class="chapter-nav__item chapter-nav__item--next chapter-nav__item--disabled">
          <span>下一章</span>
          <strong>已经是最后一章</strong>
        </span>
      )}
    </nav>
  </article>
</BaseLayout>
