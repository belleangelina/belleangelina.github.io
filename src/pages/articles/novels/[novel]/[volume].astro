---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import { getPublishedNovels } from '../../../../lib/content';

export async function getStaticPaths() {
  const novels = await getPublishedNovels();
  return novels.flatMap((novel) => novel.volumes.map((volume) => ({
    params: { novel: novel.slug, volume: volume.slug },
    props: { novel, volume }
  })));
}

const { novel, volume } = Astro.props;
---

<BaseLayout title={volume.title} description={volume.summary || `${novel.title} ${volume.title}`}>
  <section class="reading reading-wide">
    <header class="reading-header">
      <div class="eyebrow"><a href={novel.url}>{novel.title}</a></div>
      <h1>{volume.title}</h1>
    </header>

    <section class="article-list-section" aria-labelledby="chapters-title">
      <div class="section-head reveal reveal--delay-2">
        <h2 id="chapters-title">章节目录</h2>
      </div>
      {volume.chapters.length > 0 ? (
        <div class="article-list reveal reveal--delay-3">
          {volume.chapters.map((chapter) => (
            <ArticleCard title={chapter.title} url={chapter.url} date={chapter.date} label="章节" />
          ))}
        </div>
      ) : (
        <p class="empty reveal reveal--delay-3">这一卷暂时还没有已发布章节。</p>
      )}
    </section>
  </section>
</BaseLayout>
