---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPublishedNovels } from '../../../lib/content';

export async function getStaticPaths() {
  const novels = await getPublishedNovels();
  return novels.map((novel) => ({
    params: { novel: novel.slug },
    props: { novel }
  }));
}

const { novel } = Astro.props;
const chapters = novel.volumes.flatMap((volume) => volume.chapters);
const firstChapter = chapters[0];
---

<BaseLayout title={novel.title} description={novel.summary || novel.title}>
    <section class="reading reading-wide novel-detail">
        <header class="reading-header novel-hero">
            <div class="eyebrow"><a href="/articles/novels/">长篇</a></div>
            <h1>{novel.title}</h1>
            {novel.summary && <p class="novel-summary">{novel.summary}</p>}
            <div class="novel-actions">
                {firstChapter ? (
                    <a class="btn btn--primary" href={firstChapter.url}><span>开始阅读</span></a>
                ) : (
                    <span class="novel-empty-action">暂未发布章节</span>
                )}
                <span class="novel-meta">{novel.volumes.length} 卷 <i aria-hidden="true">·</i> {chapters.length} 章</span>
            </div>
        </header>

        <section class="novel-toc reveal reveal--delay-2" aria-labelledby="novel-toc-title">
            <header class="novel-toc__header">
                <h2 id="novel-toc-title">目录</h2>
                <span>共 {chapters.length} 章</span>
            </header>

            {novel.volumes.length > 0 ? (
                <div class="novel-volume-list" data-novel-volumes>
                    {novel.volumes.map((volume, volumeIndex) => (
                        <details
                            class="novel-volume"
                            data-volume-url={volume.url}
                            name="novel-volumes"
                            open={volumeIndex === 0}
                        >
                            <summary class="novel-volume__summary-row">
                                <span class="novel-volume__label">卷 {String(volume.volume).padStart(2, '0')}</span>
                                <span class="novel-volume__title">{volume.title}</span>
                                <span class="novel-volume__count">{volume.chapters.length} 章</span>
                                <span class="novel-volume__toggle" aria-hidden="true"></span>
                            </summary>

                            <div class:list={{
                                'novel-volume__body': true,
                                'novel-volume__body--chapters-only': !volume.summary
                            }}>
                                {volume.summary && <p class="novel-volume__summary">{volume.summary}</p>}

                                {volume.chapters.length > 0 ? (
                                    <ol class="novel-chapter-list">
                                        {volume.chapters.map((chapter) => (
                                            <li>
                                                <a href={chapter.url}>
                                                    <span class="novel-chapter-list__order">{String(chapter.order).padStart(2, '0')}</span>
                                                    <span class="novel-chapter-list__title">{chapter.title}</span>
                                                    <span class="novel-chapter-list__arrow" aria-hidden="true">→</span>
                                                </a>
                                            </li>
                                        ))}
                                    </ol>
                                ) : (
                                    <p class="novel-volume__empty">这一卷暂时还没有已发布章节。</p>
                                )}
                            </div>
                        </details>
                    ))}
                </div>
            ) : (
                <p class="empty">这个作品暂时还没有已发布卷或章节。</p>
            )}
        </section>
    </section>

    <script is:inline>
        (() => {
            const volumeList = document.querySelector('[data-novel-volumes]');
            if (!volumeList) return;

            const volumes = Array.from(volumeList.querySelectorAll('details[data-volume-url]'));
            let activeVolume = volumes[0];

            try {
                const stored = JSON.parse(localStorage.getItem('belle-last-reading-v1') || 'null');

                if (stored && typeof stored.url === 'string') {
                    activeVolume = volumes.find((volume) => stored.url.startsWith(volume.dataset.volumeUrl || '')) || activeVolume;
                }
            } catch (error) {
                // 阅读记录不可用时，保留第一卷为默认展开项。
            }

            volumes.forEach((volume) => {
                volume.open = volume === activeVolume;
            });
        })();
    </script>
</BaseLayout>
