---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedNovels } from '../../../lib/content';

export async function getStaticPaths() {
  const novels = await getPublishedNovels();
  return novels.map((novel) => ({
    params: { novel: novel.slug },
    props: { novel }
  }));
}

const { novel } = Astro.props;
---

<BaseLayout title={novel.title} description={novel.summary || novel.title}>
  <section class="reading reading-wide">
    <header class="reading-header">
      <div class="eyebrow"><a href="/articles/novels/">长篇</a></div>
      <h1>{novel.title}</h1>
    </header>

    <section class="article-list-section" aria-labelledby="volumes-title">
      <div class="section-head reveal reveal--delay-2">
        <h2 id="volumes-title">卷目录</h2>
      </div>
      {novel.volumes.length > 0 ? (
        <div class="article-list reveal reveal--delay-3">
          {novel.volumes.map((volume) => (
            <ArticleCard title={volume.title} url={volume.url} label="卷" />
          ))}
        </div>
      ) : (
        <p class="empty reveal reveal--delay-3">这个作品暂时还没有已发布卷或章节。</p>
      )}
    </section>
  </section>
</BaseLayout>
