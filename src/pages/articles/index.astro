---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedArticles, getPublishedNovels, getPublishedShorts, getPublishedNotes } from '../../lib/content';

const [articles, novels, shorts, notes] = await Promise.all([
  getAllPublishedArticles(),
  getPublishedNovels(),
  getPublishedShorts(),
  getPublishedNotes()
]);

const labelFor = (kind: string) => {
  if (kind === 'short') return '短篇';
  if (kind === 'note') return '记录';
  return '章节';
};
---

<BaseLayout title="文章" description="文章总览。">
  <section class="hero">
    <h1>文章</h1>
  </section>

  <section class="section" aria-labelledby="cats-title">
    <div class="section-head">
      <h2 id="cats-title">分类</h2>
      <span class="meta">共 {articles.length} 条</span>
    </div>
    <div class="category-links">
      <a href="/articles/novels/"><span>长篇</span><strong>{novels.length} 部</strong></a>
      <a href="/articles/shorts/"><span>短篇</span><strong>{shorts.length} 篇</strong></a>
      <a href="/articles/notes/"><span>记录</span><strong>{notes.length} 篇</strong></a>
    </div>
  </section>

  <section class="section" aria-labelledby="all-title">
    <div class="section-head">
      <h2 id="all-title">全部更新</h2>
      <span class="meta">按日期倒序</span>
    </div>
    {articles.length > 0 ? (
      <div class="article-list">
        {articles.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} label={labelFor(article.kind)} cover={article.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布内容。</p>
    )}
  </section>
</BaseLayout>
