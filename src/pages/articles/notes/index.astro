---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedNotes } from '../../../lib/content';

const notes = await getPublishedNotes();
---

<BaseLayout title="记录" description="记录列表。">
  <section class="hero">
    <h1>记录</h1>
  </section>

  <section class="section article-list-section" aria-labelledby="notes-title">
    <div class="section-head">
      <h2 id="notes-title">记录目录</h2>
      <span class="meta">{notes.length} 篇</span>
    </div>
    {notes.length > 0 ? (
      <div class="article-list">
        {notes.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} label="记录" cover={article.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布记录。</p>
    )}
  </section>
</BaseLayout>
