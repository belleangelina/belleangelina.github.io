---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedNotes } from '../../../lib/content';

const notes = await getPublishedNotes();
---

<BaseLayout title="记录" description="记录列表。">
  <section class="archive-hero category-hero" aria-labelledby="notes-title">
    <div>
      <p class="overline">Journal</p>
      <h1 id="notes-title">记录</h1>
      <p class="archive-lede">日常整理、临时想法与生活旁注，被收进更轻的一格。</p>
    </div>
    <div class="archive-counter" aria-label="记录数量">
      <strong>{notes.length}</strong>
      <span>notes</span>
    </div>
  </section>

  <section class="section archive-listing" aria-labelledby="notes-list-title">
    <div class="section-head section-head-large">
      <div>
        <p class="overline">Ledger</p>
        <h2 id="notes-list-title">记录目录</h2>
      </div>
      <span class="meta">{notes.length} 篇</span>
    </div>
    {notes.length > 0 ? (
      <div class="article-list">
        {notes.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} label="记录" summary={article.summary} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布记录。</p>
    )}
  </section>
</BaseLayout>
