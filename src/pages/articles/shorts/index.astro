---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedShorts } from '../../../lib/content';

const shorts = await getPublishedShorts();
---

<BaseLayout title="短篇" description="短篇列表。">
  <section class="archive-hero category-hero" aria-labelledby="shorts-title">
    <div>
      <p class="overline">Fragments</p>
      <h1 id="shorts-title">短篇</h1>
      <p class="archive-lede">独立片段、短故事和单独发光的文字，适合一口气读完。</p>
    </div>
    <div class="archive-counter" aria-label="短篇数量">
      <strong>{shorts.length}</strong>
      <span>pieces</span>
    </div>
  </section>

  <section class="section archive-listing" aria-labelledby="shorts-list-title">
    <div class="section-head section-head-large">
      <div>
        <p class="overline">Cabinet</p>
        <h2 id="shorts-list-title">短篇目录</h2>
      </div>
      <span class="meta">{shorts.length} 篇</span>
    </div>
    {shorts.length > 0 ? (
      <div class="article-list">
        {shorts.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} label="短篇" summary={article.summary} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布短篇。</p>
    )}
  </section>
</BaseLayout>
