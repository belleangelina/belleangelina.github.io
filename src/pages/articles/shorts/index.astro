---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedShorts } from '../../../lib/content';

const shorts = await getPublishedShorts();
---

<BaseLayout title="短篇" description="短篇列表。">
  <section class="hero">
    <h1>短篇</h1>
  </section>

  <section class="section article-list-section" aria-labelledby="shorts-title">
    <div class="section-head">
      <h2 id="shorts-title">短篇目录</h2>
      <span class="meta">{shorts.length} 篇</span>
    </div>
    {shorts.length > 0 ? (
      <div class="article-list">
        {shorts.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} label="短篇" cover={article.cover} />
        ))}
      </div>
    ) : (
      <p class="empty">暂时还没有已发布短篇。</p>
    )}
  </section>
</BaseLayout>
