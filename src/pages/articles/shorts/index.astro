---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getPublishedShorts } from '../../../lib/content';

const shorts = await getPublishedShorts();
---

<BaseLayout title="短篇" description="短篇列表。">
  <section class="archive-hero category-hero" aria-labelledby="shorts-title">
    <div>
      <h1 id="shorts-title" class="reveal reveal--delay-1">短篇</h1>
      <p class="archive-lede reveal reveal--delay-2">这里放单独成篇的故事和文字。</p>
    </div>
  </section>

  <section class="section archive-listing" aria-labelledby="shorts-list-title">
    <h2 id="shorts-list-title" class="visually-hidden">短篇列表</h2>
    {shorts.length > 0 ? (
      <div class="article-list reveal reveal--delay-3">
        {shorts.map((article) => (
          <ArticleCard title={article.title} url={article.url} date={article.date} label="短篇" />
        ))}
      </div>
    ) : (
      <p class="empty reveal reveal--delay-3">暂无短篇。</p>
    )}
  </section>
</BaseLayout>
